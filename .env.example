# ========================================
#  ARYN TEAM — переменные окружения
# ========================================
# Скопируйте этот файл в .env и заполните значения.
# Подробная инструкция: см. README-DEPLOY.md

# --- Frontend (нужно ДО сборки `npm run build`) ---
# Site Key Google reCAPTCHA v3 (публичный, начинается на 6L...)
VITE_RECAPTCHA_SITE_KEY=

# --- Backend (PHP читает в рантайме на хостинге) ---
# Токен Telegram-бота от @BotFather (формат: 1234567890:AA...)
TELEGRAM_BOT_TOKEN=

# ID чата/канала, куда слать заявки.
# Личный чат — узнать через @userinfobot.
# Канал — добавить бота администратором, ID начинается с -100...
TELEGRAM_CHAT_ID=

# Secret Key reCAPTCHA v3 (приватный, оставлять только на сервере)
RECAPTCHA_SECRET_KEY=
